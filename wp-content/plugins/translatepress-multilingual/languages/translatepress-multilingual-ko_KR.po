msgstr "TranslatePress 온보딩 페이지가 아닙니다."

msgid "Step %s does not exist"
msgstr "%s단계가 존재하지 않습니다"

msgid "Welcome"
msgstr "환영합니다"

msgid "Add Languages"
msgstr "언어 추가"

