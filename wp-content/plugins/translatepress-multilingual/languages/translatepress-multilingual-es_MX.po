msgstr "Agrega un desplegable flotante que sigue al usuario en todas las páginas."

#, tp-glo-ee8b4f9f
msgid "Show \"Powered by TranslatePress\""
msgstr "Mostrar \"Desarrollado por TranslatePress\""

