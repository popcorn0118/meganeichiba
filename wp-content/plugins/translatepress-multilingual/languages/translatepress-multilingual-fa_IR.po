msgstr "مرحله %s وجود ندارد"

msgid "Welcome"
msgstr "خوش آمدید"

msgid "Add Languages"
msgstr "افزودن زبان‌ها"

msgid "Enable Addons"
msgstr "فعال‌سازی افزودنی‌ها"

