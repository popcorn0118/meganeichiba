msgid "Check DNS"
msgstr "Kontrollera DNS"

#, tp-glo-e765e8ba
msgid "Checking DNS..."
msgstr "Kontrollerar DNS..."

#, tp-glo-e765e8ba
msgid "DNS is correctly configured!"
msgstr "DNS är korrekt konfigurerat!"

