"target=\"_blank\" "
"href=\"https://translatepress.com/account/?utm_source=wp-dashboard&utm_"
"medium=client-site&utm_campaign=license-deactivated\">https://"
"translatepress.com/account</a> -> Kelola Situs."

msgid ""
