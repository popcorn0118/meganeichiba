msgid "Select language"
msgstr "Dil seçin"

msgid "Choose in which language to show this element."
msgstr "Bu öğeyi hangi dilde göstereceğinizi seçin."

msgid "Exclude element from language"
msgstr "Öğeyi dilden hariç tut"

